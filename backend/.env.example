# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL="mysql://username:password@localhost:3306/task_management_db"

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET="replace_with_a_long_random_secret_string"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ✉️ Email — Azure Communication Services (Production) ✉️✉️✉️✉️
# Set EMAIL_ENABLED=false in local dev if you don't need email
EMAIL_ENABLED=true
ACS_CONNECTION_STRING=your_acs_connection_string
EMAIL_FROM="TaskHub <DoNotReply@yourdomain.azurecomm.net>"

# ✉️ (Local Dev Alternative) Gmail SMTP (Deprecated, but works via nodemailer if you switch the code back) ✉️
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_gmail_app_password
# EMAIL_FROM="TaskHub <your_email@gmail.com>"

# ── Frontend URL (for email links) ───────────────────────────────
CLIENT_URL=http://localhost:5173
